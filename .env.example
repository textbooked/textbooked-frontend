NEXT_PUBLIC_BACKEND_URL=https://api.textbooked.hofcoral.com
NEXT_PUBLIC_OPENAPI_PATH=/swagger-yaml
# Optional: override backend URL used only by Orval codegen.
# Local host example:
# ORVAL_BACKEND_URL=http://localhost:3000
# Docker compose frontend container example:
# ORVAL_BACKEND_URL=http://backend:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional in production deployments
# NEXTAUTH_URL=https://your-frontend-domain.com
# AUTH_TRUST_HOST=true
# Shared backend JWT signing secret (must match backend AUTH_JWT_SECRET).
BACKEND_JWT_SECRET=replace-with-a-long-random-secret
